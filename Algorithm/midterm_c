#include <stdio.h>
#include <stdlib.h>

// 단순 연결 리스트의 노드 구조를 구조체로 정의 [5]
typedef struct _LISTNODE_ {
    int data;
    struct _LISTNODE_ *link;
} listNode;

// 리스트의 시작을 나타내는 head 노드를 구조체로 정의 [5]
typedef struct _LINKEDLIST_H_ {
    listNode* head;
} linkedList_h;

int main(void) {
    FILE *fp = NULL;
    int num;
    long size = 0;
    
    // 공백 연결 리스트 생성 및 초기화 [7]
    linkedList_h* L = (linkedList_h*)malloc(sizeof(linkedList_h));
    L->head = NULL;

    // 1. "numbers.txt" 파일을 텍스트 읽기 모드로 열기 [1]
    fp = fopen("numbers.txt", "rt");
    if (fp == NULL) {
        printf("파일 열기 실패\n");
        return 1;
    }

    // 2 & 3. 파일의 전체 크기를 알아내기 위해 끝으로 이동 후 위치 반환 [3, 4]
    fseek(fp, 0, SEEK_END);
    size = ftell(fp);
    printf("파일 크기: %ld 바이트\n", size);

    // 4. 데이터를 처음부터 다시 읽기 위해 파일 포인터를 맨 처음으로 이동 [3]
    rewind(fp); // 또는 fseek(fp, 0, SEEK_SET);

    // 5. 파일의 끝(EOF)에 도달할 때까지 정수 데이터를 하나씩 입력받음 [2]
    while (fscanf(fp, "%d", &num) != EOF) {
        
        // 6. 새로운 데이터를 저장할 노드 동적 할당 [7]
        listNode* newNode = (listNode*)malloc(sizeof(listNode));
        newNode->data = num;
        
        // 7 & 8. 생성한 노드를 연결 리스트의 첫 번째 노드(머리)로 삽입 [6]
        newNode->link = L->head;  // 새 노드의 링크가 기존 첫 번째 노드를 가리킴
        L->head = newNode;        // 헤드 포인터를 새 노드로 갱신
    }
    
    // 파일 사용 완료 후 닫기 [8]
    fclose(fp);

    // 9 & 10. 연결 리스트의 헤드부터 시작하여 끝(NULL)까지 순회하며 출력 [7]
    printf("저장된 연결 리스트 데이터: ");
    listNode* p = L->head;
    
    while (p != NULL) {
        printf("%d ", p->data);
        p = p->link; // 다음 노드로 이동
    }
    printf("\n");

    // (참고) 프로그램 종료 전 동적 할당 메모리 해제 로직이 들어가는 것이 좋습니다. [7]
    
    return 0;
}
