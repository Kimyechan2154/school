		printf("\n* %d student\n", cnt_i + 1);
		printf("Name: %s\n", (stu + cnt_i)->name);
		printf("Major: %s\n", (*(stu + cnt_i)).major);
		printf("Age: %d\n", stu[cnt_i].age);
