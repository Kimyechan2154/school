	mulMat = (int**)calloc(row, sizeof(int*));
	assert(mulMat != NULL);

	for (cnt_i = 0; cnt_i < row; cnt_i++) {
		// 각 행(세로) 요소에 실제 정수를 저장할 가로 공간을 할당해야 함 [cite: 870, 887]
		matrixA[cnt_i] = (int*)calloc(col, sizeof(int));
		assert(matrixA[cnt_i] != NULL);
		matrixB[cnt_i] = (int*)calloc(col, sizeof(int));
		assert(matrixB[cnt_i] != NULL);
		addMat[cnt_i] = (int*)calloc(col, sizeof(int));
		assert(addMat[cnt_i] != NULL);
