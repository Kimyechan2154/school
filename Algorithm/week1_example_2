	for (cnt_i = 0; cnt_i < 3; cnt_i++) {
		printf("문장 입력\n");
		gets(buffer);
		len = strlen(buffer);
		greet2[cnt_i] = (char*)calloc(len + 1, sizeof(char));
		strncpy(greet2[cnt_i], buffer, len + 1);
	}
	printf("\n 입력된 문장.\n");
	for (cnt_i = 0; cnt_i < 3; cnt_i++) {
		printf("%s\n", greet2[cnt_i]);
	}

	for (cnt_i = 0; cnt_i < 3; cnt_i++) {
		free(greet2[cnt_i]);
	}
	
	printf("[동적 2]\n");
	printf("몇개의 문장 입력: \n");

	scanf("%d%c", &num0fStr, &temp);
	greet3 = (char**)calloc(num0fStr, sizeof(char*)); //문장의 개수마저 동적 관리

	for (cnt_i = 0; cnt_i < num0fStr; cnt_i++) {
		printf("문장 입력\n");
		gets(buffer);
		len = strlen(buffer);
		greet3[cnt_i] = (char*)calloc(len + 1, sizeof(char));
		strncpy(greet3[cnt_i], buffer, len + 1);
	}
	printf("\n 입력된 문장.\n");
	for (cnt_i = 0; cnt_i < num0fStr; cnt_i++) {
		printf("%s\n", greet3[cnt_i]);
	}
	for (cnt_i = 0; cnt_i < num0fStr; cnt_i++) {
		free(greet3[cnt_i]);
	}
	free(greet3);
}

