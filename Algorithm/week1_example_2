void inputMat(int* matrix[], int numRows, int numCols, int mod) {
	int cnt_i, cnt_j;

	for (cnt_i = 0; cnt_i < numRows; cnt_i++) {
		for (cnt_j = 0; cnt_j < numCols; cnt_j++) {
			matrix[cnt_i][cnt_j] = rand() % mod;
		}
	}
}

void printMat(int* matrix[], int numRows, int numCols) {
	int cnt_i, cnt_j;

	for (cnt_i = 0; cnt_i < numRows; cnt_i++) {
		for (cnt_j = 0; cnt_j < numCols; cnt_j++) {
			printf("%d\t", matrix[cnt_i][cnt_j]);
		}
		printf("\n");
	}
}

void matrixAdd(int* addMat[], int* matA[], int* matB[], int numRows, int numCols)
{
	int cnt_i, cnt_j;

	for (cnt_i = 0; cnt_i < numRows; cnt_i++) {
		for (cnt_j = 0; cnt_j < numCols; cnt_j++) {
			addMat[cnt_i][cnt_j] = matA[cnt_i][cnt_j] + matB[cnt_i][cnt_j];
		}
	}
}

void matrixMul(int* mulMat[], int* matA[], int* matB[], int numRows, int numCols)
{
	int cnt_i, cnt_j, cnt_k;

	for (cnt_i = 0; cnt_i < numRows; cnt_i++) {
		for (cnt_j = 0; cnt_j < numCols; cnt_j++) {
			mulMat[cnt_i][cnt_j] = 0;

			for (cnt_k = 0; cnt_k < numCols; cnt_k++) {
				mulMat[cnt_i][cnt_j] += (matA[cnt_i][cnt_k] * matB[cnt_k][cnt_j]);
			}
		}
	}
}

