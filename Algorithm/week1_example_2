void exercise3_1() {
	char greet[3][20] = { {0x00, }, }; //고정된 크기 사용해 공간 낭비 발생
	int cnt_i;

	printf("[2차원 배열]\n");
	for (cnt_i = 0; cnt_i < 3; cnt_i++) {
		printf("문장 입력:\n");
		gets(greet[cnt_i]);
