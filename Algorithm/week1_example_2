// [실습 1-2] 정적 할당(Stack)과 동적 할당(Heap)의 차이 관찰

// 1. 정적 할당 배열을 반환하려는 시도
int* testMem1()
{
	// 함수 내부(Stack)에 고정된 크기의 배열 선언
	int data[10] = { 0x00, };
	int cnt_i;

	for (cnt_i = 0; cnt_i < 10; cnt_i++) {
		data[cnt_i] = cnt_i;
		printf("%d in testMem1\n", data[cnt_i]);
	}
	// 지역 변수의 주소를 반환함 (매우 위험한 작업)
	return data;
}

// 2. 동적 할당 배열을 사용하여 안전하게 반환
int* testMem2()
{
	int* data = NULL;
	int cnt_i;

	// calloc을 사용해 힙(Heap) 영역에 메모리 할당과 동시에 모든 공간을 0으로 자동 초기화함
	data = (int*)calloc(10, sizeof(int));

	for (cnt_i = 0; cnt_i < 10; cnt_i++) {
		data[cnt_i] = cnt_i;
		printf("%d in testMem2\n", data[cnt_i]);
	}
	// 힙에 생성된 메모리는 함수가 끝나도 유지되므로 주소 반환이 안전함 
	return data;
}

