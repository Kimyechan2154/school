//실습 3-3

void inputMat(int* matrix[], int numRows, int numCols, int mod) {
	int cnt_i, cnt_j;

	for (cnt_i = 0; cnt_i < numRows; cnt_i++) {
		for (cnt_j = 0; cnt_j < numCols; cnt_j++) {
			matrix[cnt_i][cnt_j] = rand() % mod;
		}
	}
}

void printMat(int* matrix[], int numRows, int numCols) {
	int cnt_i, cnt_j;

	for (cnt_i = 0; cnt_i < numRows; cnt_i++) {
		for (cnt_j = 0; cnt_j < numCols; cnt_j++) {
			printf("%d\t", matrix[cnt_i][cnt_j]);
		}
		printf("\n");
	}
}

void matrixAdd(int* addMat[], int* matA[], int* matB[], int numRows, int numCols)
{
	int cnt_i, cnt_j;

	for (cnt_i = 0; cnt_i < numRows; cnt_i++) {
		for (cnt_j = 0; cnt_j < numCols; cnt_j++) {
			addMat[cnt_i][cnt_j] = matA[cnt_i][cnt_j] + matB[cnt_i][cnt_j];
		}
	}
}

void matrixMul(int* mulMat[], int* matA[], int* matB[], int numRows, int numCols)
{
	int cnt_i, cnt_j, cnt_k;

	for (cnt_i = 0; cnt_i < numRows; cnt_i++) {
		for (cnt_j = 0; cnt_j < numCols; cnt_j++) {
			mulMat[cnt_i][cnt_j] = 0;

			for (cnt_k = 0; cnt_k < numCols; cnt_k++) {
				mulMat[cnt_i][cnt_j] += (matA[cnt_i][cnt_k] * matB[cnt_k][cnt_j]);
			}
		}
	}
}

void exercise3_3()
{
	int row, col;
	int **matrixA = NULL, **matrixB = NULL;
	int **addMat = NULL, **mulMat = NULL;
	int cnt_i, cnt_j;

	srand(time(NULL));

	printf("행, 열 입력.\n");
	scanf("%d%d", &row, &col);

	matrixA = (int**)calloc(row, sizeof(int*));
	assert(matrixA != NULL);

	matrixB = (int**)calloc(row, sizeof(int*));
	assert(matrixB != NULL);
	
	addMat = (int**)calloc(row, sizeof(int*));
	assert(addMat != NULL);
	
	mulMat = (int**)calloc(row, sizeof(int*));
	assert(mulMat != NULL);

	for (cnt_i = 0; cnt_i < row; cnt_i++) {
		// 각 행(세로) 요소에 실제 정수를 저장할 가로 공간을 할당해야 함 [cite: 870, 887]
		matrixA[cnt_i] = (int*)calloc(col, sizeof(int));
		assert(matrixA[cnt_i] != NULL);
		matrixB[cnt_i] = (int*)calloc(col, sizeof(int));
		assert(matrixB[cnt_i] != NULL);
		addMat[cnt_i] = (int*)calloc(col, sizeof(int));
		assert(addMat[cnt_i] != NULL);
		mulMat[cnt_i] = (int*)calloc(col, sizeof(int));
		assert(mulMat[cnt_i] != NULL);
	}

	inputMat(matrixA, row, col, 16);
	inputMat(matrixB, row, col, 16);

	printf("[matrix A]\n");
	printMat(matrixA, row, col);

	printf("[matrix B]\n");
	printMat(matrixB, row, col);

	matrixAdd(addMat, matrixA, matrixB, row, col);
	matrixMul(mulMat, matrixA, matrixB, row, col);

	printf("[matrix addition]\n");
	printMat(addMat, row, col);

	printf("[matrix multiplication]\n");
	printMat(mulMat, row, col);

	for (cnt_i = 0; cnt_i < row; cnt_i++)
	{
		free(matrixA[cnt_i]);
		free(matrixB[cnt_i]);
		free(addMat[cnt_i]);
		free(mulMat[cnt_i]);
	}
	free(matrixA);
	free(matrixB);
	free(addMat);
	free(mulMat);
}

//실습 3-4

int** allocMatrix(int row, int col) {
	int** matrix = NULL;
	int cnt_i;

	matrix = (int**)calloc(row, sizeof(int*));
	assert(matrix != NULL);
	for (cnt_i = 0; cnt_i < row; cnt_i++) {
		matrix[cnt_i] = (int*)calloc(col, sizeof(int));
		assert(matrix[cnt_i] != NULL);
	}
	return matrix;
}

void freeMatrix(int** matrix, int row) {
	int cnt_i;

	for (cnt_i = 0; cnt_i < row; cnt_i++) {
		free(matrix[cnt_i]);
	}
	free(matrix);
}

