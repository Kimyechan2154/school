	printf("행, 열 입력.\n");
	scanf("%d%d", &row, &col);

	matrixA = allocMatrix(row, col); //초기화 함수
	matrixB = allocMatrix(row, col);
	addMat = allocMatrix(row, col);
	mulMat = allocMatrix(row, col);

	inputMat(matrixA, row, col, 16); //랜덤 값 삽입
