void generate(int data[], int mod, int size) 
{
	int cnt_i;
	srand(time(NULL));
	for (cnt_i = 0; cnt_i < 10; cnt_i++) {
		data[cnt_i] = rand() % mod;
	}
}

int getSum(int data[], int size)
{
	int cnt_i;
	int sum = 0;
	for (cnt_i = 0; cnt_i < size; cnt_i++) {
		sum += data[cnt_i];
	}
	return sum;
}

void printArray(int data[], int size)
{
	int cnt_i;
	
	for (cnt_i = 0; cnt_i < size; cnt_i++) {
		if ((cnt_i != 0) && !(cnt_i % 8)) {
			printf("\n");
		}
		printf("%6d", data[cnt_i]);
	}
	printf("\n");
}
