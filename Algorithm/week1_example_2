int** allocMatrix(int row, int col) {
	int** matrix = NULL;
	int cnt_i;

	matrix = (int**)calloc(row, sizeof(int*));
	assert(matrix != NULL);
	for (cnt_i = 0; cnt_i < row; cnt_i++) {
		matrix[cnt_i] = (int*)calloc(col, sizeof(int));
		assert(matrix[cnt_i] != NULL);
	}
	return matrix;
}

void freeMatrix(int** matrix, int row) {
	int cnt_i;

	for (cnt_i = 0; cnt_i < row; cnt_i++) {
		free(matrix[cnt_i]);
	}
	free(matrix);
}

