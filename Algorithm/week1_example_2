void ADD(int* add[], int* matA[], int* matB[], int Row, int Col)
{
	for (int i = 0; i < Row; i++)
	{
		for (int j = 0; j < Col; j++)
		{
			add[i][j] = matA[i][j] + matB[i][j];
		}
	}
}

void MUL(int* mul[], int* matA[], int* matB[], int Row, int Col)
{
	for (int i = 0; i < Row; i++)
	{
		for (int j = 0; j < Col; j++)
		{
			for (int k = 0; k < Row; k++)
			{
				mul[i][j] = matA[i][k] * matA[k][j];
			}
		}
	}
}

