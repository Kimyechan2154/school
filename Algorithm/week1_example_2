void exercise4() {
	char greet[3][20] = { {0x00, }, }; //고정된 크기 사용해 공간 낭비 발생
	int cnt_i;

	printf("[2차원 배열]\n");
	for (cnt_i = 0; cnt_i < 3; cnt_i++) {
		printf("문장 입력:\n");
		gets(greet[cnt_i]);
	}

	printf("\n 입력된 문장은: \n");
	for (cnt_i = 0; cnt_i < 3; cnt_i++) {
		printf("%s\n", greet[cnt_i]);
	}

	char buffer[32];
	char *greet2[3] = {0x00, }; //포인터 배열을 이용해 문장의 길이에 맞춰 메모리 할당
	char **greet3 = NULL;
	char temp;
	int len;
	int num0fStr;

	printf("[동적 할당 이용 1]\n");
	for (cnt_i = 0; cnt_i < 3; cnt_i++) {
		printf("문장 입력\n");
		gets(buffer);
		len = strlen(buffer);
		greet2[cnt_i] = (char*)calloc(len + 1, sizeof(char));
		strcpy(greet2[cnt_i], buffer, len + 1);
	}
	printf("\n 입력된 문장.\n");
	for (cnt_i = 0; cnt_i < 3; cnt_i++) {
		printf("%s\n", greet2[cnt_i]);
	}

	for (cnt_i = 0; cnt_i < 3; cnt_i++) {
		free(greet2[cnt_i]);
	}
	
	printf("[동적 2]\n");
	printf("몇개의 문장 입력: \n");

	scanf("%d%c", &num0fStr, &temp);
	greet3 = (char**)calloc(num0fStr, sizeof(char*)); //문장의 개수마저 동적 관리

	for (cnt_i = 0; cnt_i < num0fStr; cnt_i++) {
		printf("문장 입력\n");
		gets(buffer);
		len = strlen(buffer);
		greet3[cnt_i] = (char*)calloc(len + 1, sizeof(char));
		strcpy(greet3[cnt_i], buffer, len + 1);
	}
	printf("\n 입력된 문장.\n");
	for (cnt_i = 0; cnt_i < num0fStr; cnt_i++) {
		printf("%s\n", greet3[cnt_i]);
	}
	for (cnt_i = 0; cnt_i < num0fStr; cnt_i++) {
		free(greet3[cnt_i]);
	}
	free(greet3);
}

