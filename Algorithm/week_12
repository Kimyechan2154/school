// 2. 이진 트리 중위 순회(Inorder) 출력 함수
void displayInorder(TREE* root) {
	if (root != NULL) {
		displayInorder(root->left);
		printf("%c_", root->key);
		displayInorder(root->right);
	}
}

// 3. 트리 시각화 함수를 위한 보조 함수 (오른쪽-루트-왼쪽 순서로 출력하여 눕혀진 트리 형태 구현)
void showTree_helper(TREE* root, int depth) {
	int i;
	if (root != NULL) {
		showTree_helper(root->right, depth + 1);
		for (i = 0; i < depth; i++) {
			printf("....."); // 깊이에 따른 들여쓰기
		}
		printf("%c\n", root->key);
		showTree_helper(root->left, depth + 1);
	}
}

// 3. 트리 시각화 함수
void showTree(TREE* root) {
	printf("\n");
	showTree_helper(root, 0);
	printf("\n");
}

