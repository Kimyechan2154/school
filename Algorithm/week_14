#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <stdlib.h>
#include <memory.h>
#include <assert.h>

#define INCREASING 1
#define DECREASING 2

void printfArray(int* arr, int size)
{
	for (int i = 0; i < size; i++)
		printf("%d ", arr[i]);
	printf("\n");
}

void test_insert(int dir)
{
	int data[10] = { 69, 10, 30, 2, 16, 8, 31, 22, 17, 91 };
	int i, j;
	int key;

	printf("\n[원본]\n");
	printfArray(data, 10);
	
	if (dir == INCREASING)
	{
		printf("\n오름차순\n");
		for (i = 1; i < 10; i++)
		{
			key = data[i];

			for (j = i - 1; j >= 0 && data[j] > key; j--)
			{
				data[j + 1] = data[j];
			}
			data[j + 1] = key;

			printf("\n[%d]단계\n", i);
			printfArray(data, 10);
		}
	}

}

int main() {

	test_insert(1);
	
	return 0;
}
