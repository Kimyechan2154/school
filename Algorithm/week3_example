//실습 6

void exercise6()
{
	char buf[] = "Hello world";
	int data = 100;
	FILE* bfp = NULL;
	FILE* tfp = NULL;

	bfp = fopen("exe6_binary.dat", "wb");
	assert(bfp != NULL);

	tfp = fopen("exe6_binary.dat", "wb");
	assert(tfp != NULL);

	//2진법으로 buf 안에 있는 내용을 sizeof(buf)크기 만큼 1번 bfp안에 저장
	fwrite(buf, sizeof(buf), 1, bfp);
	fwrite(&data, sizeof(buf), 1, bfp);

	fprintf(tfp, "%s", buf);
	fprintf(tfp, "%d", data);

	if (bfp != NULL)
	{
		fclose(bfp);
	}
	if (tfp != NULL)
	{
		fclose(tfp);
	}
}

//실습 8

void exercise8()
	{
	int cnt_i;
	int dataList[100] = { 0x00, };
	int data = 0x00;
	FILE* bfp = NULL;

	bfp = fopen("exe7_binary.dat", "wb");
	assert(bfp != NULL);

	for (cnt_i = 0; cnt_i < 100; cnt_i++)
	{
		dataList[cnt_i] = cnt_i;
	}

	fwrite(dataList, sizeof(dataList), 1, bfp);
	if (bfp != NULL)
	{
		fclose(bfp);
	}

	bfp = fopen("exe7_binary.dat", "rb");
	assert(bfp != NULL);

	//4바이트 크기의 50번째로 점프
	fseek(bfp, 4 * (50 - 1), SEEK_SET);
	fread(&data, sizeof(int), 1, bfp);
	printf("%d\n", data);

	if (bfp != NULL)
	{
		fclose(bfp);
	}
} 

