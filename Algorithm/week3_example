//실습2

void exercise2()
{
	FILE* fp = NULL;
	int cnt_i;
	int data[5] = { 0x00, };

	printf("Reading 5numbers:\n");
	
	fp = fopen("data0.txt", "r");

	if (fp == NULL) {
		fprintf(stderr, "fopen() error\n");
	}

	for (cnt_i = 0; cnt_i < 5; cnt_i++)
	{// fscanf는 파일을 읽어서 프로그램 변수에 저장
		fscanf(fp, "%d", &data[cnt_i]);
		printf("%d\n", data[cnt_i]);
	}

	if (fp != NULL) {
		fclose(fp);
	}
}

//실습2-2

void exercise2_2()
{
	FILE* fp = NULL;
	char ch;
	
	//내용 작성
	fp = fopen("data0.txt", "wt");

	if (fp == NULL) {
		fprintf(stderr, "fopen() error\n");
		return;
	}

	printf("문장입력: \n");
	while (1) {
		ch = getchar(); //문자 하나 받아와 ch에 저장
		if (ch == '\n') { //엔터시 입력 종료
			break;
		}
		fputc(ch, fp); //ch에 담긴 문자 하나를 fp 파일에 저장
	}

	if (fp != NULL) {
		fclose(fp);
	}

	//작성한 내용 읽기
	fp = fopen("text.txt", "rt");
	if (fp == NULL) {
		fprintf(stderr, "fopen() error\n");
		return;
	}
	printf("입력한 문장은:\n");
	while (1) {
		ch = fgetc(fp);
		if (ch == EOF) { //EOF = -1
			break;
		}
		printf("%c", ch);
	}
}

//실습3

void exercise3()
{
	FILE* fp = NULL;
	char buffer[128] = { 0x00, };

	fp = fopen("string.txt", "wt");

	if (fp == NULL) {
		fprintf(stderr, "fopen() error\n");
		return;
	}

	printf("문장 입력\n");

	// buffer 안에 저장 sizeof(buffer) 배열의 크기 만큼, stdin키보드로 입력
	if (fgets(buffer, sizeof(buffer), stdin) != NULL) {
		fputs(buffer, fp); // 파일 내부에 저장
	}

	if (fp != NULL) {
		fclose(fp);
	}

	fp = fopen("string.txt", "rt");
	if (fp == NULL) {
		fprintf(stderr, "fopen() error\n");
		return;
	}

	printf("입력한 문장은:\n");
	if (fgets(buffer, sizeof(buffer), fp) != NULL) {
		fputs(buffer, stdout);
	}

}

//실습4

void exercise4()
{
	FILE *fp_src = NULL;
	FILE *fp_dst = NULL;
	char buf[128];

	fp_src = fopen("src.txt", "rt");
	fp_dst = fopen("dst.txt", "wt");

	assert(fp_src != NULL);
	assert(fp_dst != NULL);

	printf("복사 시작\n");
	/*fgets 함수를 이용해 fp_src안에 있는 내용을 
	문자열 단위로 받아와 buf안에 저장 sizeof(buf) 초과 방지*/
	while (fgets(buf, sizeof(buf), fp_src) != NULL) {
		fputs(buf, fp_dst); //fp_dst안에 한글자식 저장
	}
	printf("복사 완료\n");

	if (fp_src != NULL) {
		fclose(fp_src);
	}
	if(fp_dst != NULL) {
		fclose(fp_dst);
	}
}

//실습5

void exercise5() 
{
	FILE* wfp = NULL;
	FILE* ifp = NULL;
	char buf[128] = { 0x00, };

	wfp = fopen("test.txt", "w");
	assert(wfp != NULL); //코딩중 오류

	fprintf(wfp, "Hello, world\n");//파일에 글 저장

	if (wfp != NULL) //프로그램 돌아가는중 오류
	{
		fclose(wfp);
	}

	//위에서 저장한 test.txt를 읽어옴
	ifp = fopen("test.txt", "r");
	assert(ifp != NULL);

	fgets(buf, sizeof(buf), ifp);
	
	printf("[First]\n");
	printf("Read: %s", buf);

	if (ifp != NULL)
	{
		fclose(ifp);
	}

	wfp = fopen("test.txt", "a");
	assert(wfp != NULL);

	fprintf(wfp, "Hello, student!\n");
	fprintf(wfp, "Good bye!");

	if (wfp != NULL)
	{
		fclose(wfp);
	}

	ifp = fopen("test.txt", "r");
	assert(ifp != NULL);
	
	printf("\n\n[2]\n");
	while (!feof(ifp)) //feof = 파일 끝 이면 1 / file EOF
	{
		memset(buf, 0, sizeof(buf)); //buf 내용 0으로 초기화
		fgets(buf, sizeof(buf), ifp);
		printf("Read: %s\n", buf);
	}

	if (ifp != NULL)
	{
		fclose(ifp);
	}
}

